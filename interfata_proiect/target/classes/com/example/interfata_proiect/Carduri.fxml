<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="700.0" prefWidth="400.0" style="-fx-background-color: #005B00;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.interfata_proiect.Carduri">
    <children>
        <Text fill="#ffed00" layoutX="118.0" layoutY="39.0" text="Cardurile Tale">
            <font>
                <Font name="Times New Roman" size="28.0" />
            </font>
        </Text>
        <Button fx:id="addCardBtn" layoutX="157.0" layoutY="528.0" mnemonicParsing="false" onAction="#addCard" style="-fx-background-color: #ffed00; -fx-text-fill: #004800; -fx-background-radius: 15;" text="Add Card">
            <font>
                <Font name="Times New Roman" size="16.0" />
            </font>
        </Button>
        <TableView fx:id="cardTable" layoutX="19.0" layoutY="74.0" prefHeight="418.0" prefWidth="366.0" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-background-color: #005B00; -fx-border-color: #005B00;">
            <columns>
                <TableColumn fx:id="numberCol" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Number" />
                <TableColumn fx:id="cvvCol" prefWidth="120.0" style="-fx-alignment: CENTER;" text="CVV" />
                <TableColumn fx:id="expCol" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Expiration" />
            </columns>
        </TableView>
        <Rectangle fx:id="reg1" arcHeight="5.0" arcWidth="5.0" fill="#004800" height="100.0" layoutX="-5.0" layoutY="608.0" stroke="#ffed00" strokeType="INSIDE" width="409.0" />
        <Button fx:id="transferbani" layoutX="47.0" layoutY="639.0" mnemonicParsing="false" onAction="#Transfer" style="-fx-background-color: #004800; -fx-background-radius: 20;">
            <graphic>
                <FontIcon iconColor="#ffed00" iconLiteral="bi-arrow-left-right" iconSize="30" />
            </graphic>
        </Button>
        <Button fx:id="acasa" layoutX="172.0" layoutY="632.0" mnemonicParsing="false" onAction="#home" style="-fx-background-color: #004800; -fx-background-radius: 20;">
            <graphic>
                <FontIcon fill="#004800" iconColor="#ffed00" iconLiteral="bi-house-door" iconSize="40" text="" wrappingWidth="40.0" />
            </graphic>
        </Button>
        <Button fx:id="card" layoutX="306.0" layoutY="639.0" mnemonicParsing="false" style="-fx-background-color: #004800; -fx-background-radius: 20;">
            <graphic>
                <FontIcon iconColor="#ffed00" iconLiteral="fa-credit-card-alt" iconSize="30" />
            </graphic>
        </Button>
    </children>
</AnchorPane>
